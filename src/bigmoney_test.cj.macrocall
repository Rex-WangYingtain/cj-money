/* 8.1 */@Attribute[TEST_GENERATED] class BigMoneyInitTest <: TestClass {
/* 8.2 */    @Attribute[TestCase_183]
/* 8.3 */    public func test1() {
/* 8.4 */        let currencies: Currencies = Currencies.getCurrencies()
/* 8.5 */        let currency: Currency = match(currencies.currencyByCode("KYD")) {
/* 8.6 */            case None => throw NoneValueException("没有找到Currency标准KYD")
/* 8.7 */            case Some(v) => v
/* 8.8 */        }
/* 8.9 */        let bm: BigMoney = BigMoney("1213124543253654325132543564651234431244412421154324133", currency)
/* 8.10 */        expectEqual("BigInt(\"121312454325365432513254356465123443124441242115432413300\")", "bm.amount", BigInt("121312454325365432513254356465123443124441242115432413300"), bm.amount)
/* 8.11 */        expectEqual("\".\"", "bm.currency.decimal", ".", bm.currency.decimal)
/* 8.12 */        expectEqual("\",\"", "bm.currency.thousand", ",", bm.currency.thousand)
/* 8.13 */        expectEqual("\"KYD\"", "bm.currency.code", "KYD", bm.currency.code)
/* 8.14 */        expectEqual("2", "bm.currency.fraction", 2, bm.currency.fraction)
/* 8.15 */        expectEqual("\"136\"", "bm.currency.numericCode", "136", bm.currency.numericCode)
/* 8.16 */        expectEqual("\"$\"", "bm.currency.grapheme", "$", bm.currency.grapheme)
/* 8.17 */        expectEqual("\"$1\"", "bm.currency.template", "$1", bm.currency.template)
/* 8.18 */    }
